TZ=America/New_York
GIT_REPO_URL=
GIT_REF=
ENABLE_GIT_SYNC_ON_BOOT=1
ENABLE_IMAGE_PULL_ON_BOOT=1

DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=3
# Add new required variables below as needed. Update this file when new variables are added to the stack.
# Admin UI exposure defaults to localhost-only. Use a private LAN IP or VPN-reachable
# address if you intentionally want off-box access inside a trusted network.
ADMIN_BIND_IP=CHANGE_ME_TO_VM_LAN_IP
CONSOLE_PORT=8088
PORTAINER_PORT=9443
FILEBROWSER_PORT=8080
OLIVETIN_PORT=1337

CONSOLE_IMAGE=mc-paper-admin-console:2026.05.26
PORTAINER_IMAGE=portainer/portainer-ce:lts
FILEBROWSER_IMAGE=filebrowser/filebrowser:v2.63.3
OLIVETIN_IMAGE=mc-paper-admin-olivetin:2026.05.24
OLIVETIN_BASE_IMAGE=bnhf/olivetin:2026.05.24
MARIADB_IMAGE=mariadb:11.8

FILEBROWSER_ADMIN_USER=admin
FILEBROWSER_ADMIN_PASSWORD=change-me-filebrowser
FILEBROWSER_PORTAL_NAME=Minecraft Admin Files

OLIVETIN_MOD_USERNAME=mod
OLIVETIN_MOD_PASSWORD=change-me-mod
OLIVETIN_ADMIN_USERNAME=admin
OLIVETIN_ADMIN_PASSWORD=change-me-admin
OLIVETIN_PAGE_TITLE=Minecraft Operations
CONSOLE_ADMIN_USER=admin
CONSOLE_ADMIN_PASSWORD=change-me-console-admin
CONSOLE_MOD_USER=mod
CONSOLE_MOD_PASSWORD=change-me-console-mod
CONSOLE_SESSION_SECRET=change-me-console-session-secret
CONSOLE_PAGE_TITLE=Minecraft Control Plane

MARIADB_DATABASE=luckperms
MARIADB_USER=luckperms
MARIADB_PASSWORD=change-me-db-user
MARIADB_ROOT_PASSWORD=change-me-db-root
MARIADB_BIND_IP=0.0.0.0
MARIADB_PORT=3306
LP_DB_HOST=CHANGE_ME_TO_VM_LAN_IP_OR_HOSTNAME
LP_DB_PORT=3306

# Optional comma-separated bootstrap assignments applied by scripts/bootstrap-permissions.sh
LP_BOOTSTRAP_MEMBER_PLAYERS=
LP_BOOTSTRAP_MOD_PLAYERS=
LP_BOOTSTRAP_ADMIN_PLAYERS=

# Path to the sibling mc-backup-google-drive repo for restore and offsite backup workflows.
BACKUP_COMPANION_ROOT=/opt/minecraft-backup-google-drive

# Export these from the sibling mc-paper-velocity-geyser-stack repo:
#   ./scripts/export-admin-target-env.sh > ../mc-paper-admin-stack/.env
TARGET_STACK_ROOT=
TARGET_COMPOSE_PROJECT_DIR=
TARGET_COMPOSE_FILE=
TARGET_DATA_DIR=
TARGET_BACKUPS_DIR=
TARGET_ACCESS_DIR=
TARGET_INVITE_PLAYERS_FILE=
TARGET_BACKUP_SCRIPT=
TARGET_SYNC_WHITELIST_SCRIPT=
TARGET_PROXY_CONTAINER=
TARGET_LOBBY_CONTAINER=
TARGET_SURVIVAL_CONTAINER=
TARGET_CREATIVE_CONTAINER=
